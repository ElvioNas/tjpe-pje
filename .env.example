# Arquivo de exemplo para armazenar credenciais com segurança
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env no repositório

# Credenciais do TJPE
TJPE_USER=seu_cpf_aqui
TJPE_PASSWORD=sua_senha_aqui

# Configurações adicionais (opcional)
TJPE_WAIT_TIME=2
TJPE_HEADLESS=false
